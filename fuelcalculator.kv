ScreenManager:
    Screen:
        name: 'sprint'

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            BoxLayout:
                orientation: 'vertical'
                size_hint: 1, None
                height: self.minimum_height
                spacing: 60
                padding: 70

                # Title
                Label:

                    font_name: 'Orbitron.ttf'

                    text: 'FUEL CALCULATOR'
                    font_size: '60sp'
                    size_hint_y: None
                    height: 200

                # Mode selection (Sprint / Endurance)
                BoxLayout:
                    size_hint_y: None
                    height: 60
                    spacing: 30


                    ToggleButton:
                        font_name: 'Orbitron.ttf'
                        background_color: (0.8, 0.1, 0.1, 1) if self.state == 'down' else (0.3, 0.3, 0.3, 1)
                        text: 'Sprint'
                        group: 'race_mode'
                        state: 'down'
                        font_size: '20sp'
                        on_press: app.switch_to_sprint()

                    ToggleButton:
                        font_name: 'Orbitron.ttf'
                        id: endurance_btn
                        background_color: (0.8, 0.1, 0.1, 1) if self.state == 'down' else (0.3, 0.3, 0.3, 1)
                        text: 'Endurance'
                        group: 'race_mode'
                        font_size: '20sp'
                        on_press: app.switch_to_endurance()

                # Inputs block
                GridLayout:
                    id: input_grid
                    font_name: 'Orbitron.ttf'
                    cols: 2
                    spacing: 40
                    size_hint_y: None
                    height: self.minimum_height

                    # Race time
                    Label:
                        text: 'Race time:'
                        font_name: 'Orbitron.ttf'
                        halign: 'left'
                        valign: 'middle'
                        font_size: '30sp'


                    TextInput:
                        id: race_time
                        hint_text: 'minutes'
                        font_name: 'Orbitron.ttf'
                        multiline: False
                        size_hint_y: None
                        height: 80
                        font_size: '20sp'
                        halign: 'center'
                        padding_y: [20, 20]

                    # Lap time
                    Label:
                        text: 'Lap time:'
                        font_name: 'Orbitron.ttf'
                        halign: 'left'
                        valign: 'middle'
                        font_size: '30sp'

                    TextInput:
                        id: lap_time
                        hint_text: 'mm:ss'
                        font_name: 'Orbitron.ttf'
                        multiline: False
                        size_hint_y: None
                        height: 80
                        font_size: '20sp'
                        halign: 'center'
                        padding_y: [20, 20]

                    # Fuel per lap
                    Label:
                        text: 'Fuel per lap:'
                        font_name: 'Orbitron.ttf'
                        halign: 'left'
                        valign: 'middle'
                        font_size: '30sp'

                    TextInput:
                        id: fuel_per_lap
                        hint_text: 'liters'
                        font_name: 'Orbitron.ttf'
                        multiline: False
                        size_hint_y: None
                        height: 80
                        font_size: '20sp'
                        halign: 'center'
                        padding_y: [20, 20]

                # Calculate button
                Button:
                    id: calculate_btn
                    font_name: 'Orbitron.ttf'
                    background_color: 0.8, 0.1, 0.1, 1
                    text: 'Calculate'
                    size_hint_y: None
                    height: 80
                    font_size: '30sp'
                    on_press: app.calculate()

                # Result output
                Label:
                    font_name: 'Orbitron.ttf'
                    id: result_label
                    text: 'Result will appear here'
                    font_size: '25sp'
                    size_hint_y: None
                    height: 100
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.width, self.height

    Screen:
        name: 'endurance'

        BoxLayout:
            orientation: 'vertical'
            padding: 40
            spacing: 20

            Label:
                text: 'FUEL CALCULATOR'
                font_name: 'Orbitron.ttf'
                font_size: '60sp'
                size_hint_y: None
                height: 200

            BoxLayout:
                size_hint_y: None
                height: 60
                spacing: 30

                ToggleButton:
                    font_name: 'Orbitron.ttf'
                    text: 'Sprint'
                    group: 'race_mode2'
                    background_color: (0.3, 0.3, 0.3, 1)
                    on_press: app.switch_to_sprint()

                ToggleButton:
                    font_name: 'Orbitron.ttf'
                    text: 'Endurance'
                    group: 'race_mode2'
                    state: 'down'
                    background_color: (0.8, 0.1, 0.1, 1)

            Label:
                text: 'Endurance mode coming soon!'
                font_name: 'Orbitron.ttf'
                halign: 'center'
                valign: 'middle'
                text_size: self.width, self.height
                font_size: '35sp'